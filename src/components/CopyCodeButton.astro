<script>
  const copyButtonLabel = "Sao chép";
  const copiedLabel = "Đã chép";
  const copyAriaDefault = "Sao chép mã nguồn";
  const copyAriaCopied = "Đã sao chép mã vào bộ nhớ tạm";

  function getOrCreateCopyStatus(): HTMLDivElement {
    let el = document.getElementById("copy-code-status");
    if (!el) {
      el = document.createElement("div");
      el.id = "copy-code-status";
      el.setAttribute("role", "status");
      el.setAttribute("aria-live", "polite");
      el.className = "";
      document.body.appendChild(el);
    }
    return el as HTMLDivElement;
  }

  const codeBlocks = Array.from(document.querySelectorAll("pre"));

  for (let codeBlock of codeBlocks) {
    const wrapper = document.createElement("div");
    wrapper.style.position = "relative";

    const copyButton = document.createElement("button");
    copyButton.type = "button";
    copyButton.className =
      "absolute top-4 right-4 rounded-md border-2 border-solid border-primary-400/70 bg-white/90 px-2 py-1 text-sm text-primary-800 shadow-sm backdrop-blur-sm hover:border-primary-500 hover:bg-primary-50/90 hover:text-primary-950 dark:border-primary-600/60 dark:bg-zinc-900/80 dark:text-primary-200 dark:hover:border-primary-400 dark:hover:text-primary-50";
    copyButton.textContent = copyButtonLabel;
    copyButton.setAttribute("aria-label", copyAriaDefault);

    codeBlock.appendChild(copyButton);
    codeBlock.parentNode?.insertBefore(wrapper, codeBlock);
    wrapper.appendChild(codeBlock);

    copyButton.addEventListener("click", async () => {
      await copyCode(codeBlock, copyButton);
    });
  }

  async function copyCode(block: HTMLPreElement, button: HTMLButtonElement) {
    const code = block.querySelector("code");
    const text = code?.innerText ?? "";

    await navigator.clipboard.writeText(text);

    button.textContent = copiedLabel;
    button.setAttribute("aria-label", copyAriaCopied);
    const status = getOrCreateCopyStatus();
    status.textContent = "Đã sao chép mã vào bộ nhớ tạm.";

    setTimeout(() => {
      button.textContent = copyButtonLabel;
      button.setAttribute("aria-label", copyAriaDefault);
      status.textContent = "";
    }, 700);
  }
</script>
