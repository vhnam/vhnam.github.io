---
import { Image } from "astro:assets";
import { getAverageColor } from "fast-average-color-node";

import FormattedDate from "./FormattedDate.astro";

const { post, category } = Astro.props;

const cover = post.data.cover ?? "/placeholder-social.jpg";

const backgroundColorHex = await (async () => {
  if (typeof cover !== "object" || cover === null) {
    return "transparent";
  }
  const fsPath =
    "fsPath" in cover &&
    typeof (cover as { fsPath?: unknown }).fsPath === "string"
      ? (cover as { fsPath: string }).fsPath
      : null;
  if (!fsPath) {
    return "transparent";
  }
  try {
    return (await getAverageColor(fsPath)).hex;
  } catch {
    return "transparent";
  }
})();
---

<li
  class="flex flex-col items-center gap-0 overflow-hidden rounded-2xl border border-primary-200/55 bg-white/90 px-4 shadow-sm shadow-primary-500/8 backdrop-blur-sm md:flex-row md:gap-6 dark:border-primary-800/35 dark:bg-zinc-900/85 dark:shadow-none"
>
  <div class="relative overflow-hidden min-w-40 rounded">
    <div
      class="flex items-center my-4 rounded-sm"
      style={`background-color: ${backgroundColorHex}`}
    >
      <Image
        src={cover}
        width={160}
        height={160}
        class="h-full min-w-full object-cover hover:scale-[101%] transition-all duration-200 rounded-sm"
        alt={post.data.title}
        quality="low"
      />
    </div>
  </div>
  <div class="w-full pb-4 md:py-4">
    <FormattedDate pubDate={post.data.pubDate} />
    <a
      href={`/${category}/${post.id}/`}
      class="font-display block pb-1 text-lg text-stone-900 transition-colors md:text-xl hover:text-primary-700 dark:text-zinc-100 dark:hover:text-primary-400"
    >
      {post.data.title}
    </a>
    <p class="text-sm text-stone-600 dark:text-zinc-400">
      {post.data.description}
    </p>
  </div>
</li>
