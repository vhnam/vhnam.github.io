---
export interface Props {
  tag: {
    name: string;
  };
  slug: string;
}

const { tag, slug } = Astro.props;
---

<a href={`/tags/${slug}`}>
  <span
    class="me-2 rounded-full border border-primary-200/70 bg-primary-50/60 px-2.5 py-1 text-xs font-semibold tracking-wide text-primary-900 backdrop-blur-sm transition-colors hover:border-primary-300 hover:bg-primary-100/80 dark:border-primary-700/50 dark:bg-primary-950/35 dark:text-primary-200 dark:hover:border-primary-500/60 dark:hover:bg-primary-950/55"
  >
    {tag.name}
  </span>
</a>
