---
import { SITE_TITLE } from "../consts";

import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
---

<header>
  <a href="#main-content" class="skip-to-content">Chuyển đến nội dung chính</a>
  <nav
    aria-label="Điều hướng chính"
    class="fixed inset-x-0 top-0 z-50 border-b border-primary-200/70 bg-white/90 backdrop-blur-md dark:border-primary-800/45 dark:bg-zinc-900/90"
  >
    <div class="container mx-auto">
      <div class="flex items-centers justify-between py-6 px-4 xl:px-0">
        <a
          href="/"
          class="font-display text-2xl font-bold text-stone-900 transition-colors hover:text-primary-600 dark:text-zinc-100 dark:hover:text-primary-400"
        >
          {SITE_TITLE}
        </a>
        <div class="flex items-center gap-6">
          <HeaderLink href="/tutorials">Phần mềm</HeaderLink>
          <HeaderLink href="/hobbies">Giải trí</HeaderLink>
          <ThemeToggle />
        </div>
      </div>
    </div>
  </nav>
</header>
