---
import Flickr from "./Icon/Flickr.astro";
import GitHub from "./Icon/GitHub.astro";
import LinkedIn from "./Icon/LinkedIn.astro";
import YouTube from "./Icon/YouTube.astro";

const today = new Date();
---

<footer class="container mx-auto">
  <div
    class="border-t border-primary-200/60 px-4 py-6 dark:border-primary-800/40 xl:px-0"
  >
    <div class="flex items-center justify-between">
      <span class="text-sm text-stone-600 dark:text-zinc-500"
        >&copy; {today.getFullYear()} Nam Vo's blog.</span
      >
      <span class="flex gap-4">
        <a
          href="/policy-privacy"
          class="text-sm text-stone-600 underline-offset-2 hover:text-primary-600 hover:underline dark:text-zinc-500 dark:hover:text-primary-400"
          >Điều khoản</a
        >
        <a
          href="/rss.xml"
          class="text-sm text-stone-600 underline-offset-2 hover:text-primary-600 hover:underline dark:text-zinc-500 dark:hover:text-primary-400"
          >RSS</a
        >
      </span>
    </div>
  </div>
  <div class="flex justify-center gap-3 pb-20">
    <a
      aria-label="LinkedIn's Nam Vo"
      href="https://www.linkedin.com/in/namvh"
      target="_blank"
      rel="noopener noreferrer"
      class="bg-blue-600 hover:bg-blue-500 active:bg-blue-800 p-2 font-semibold text-white inline-flex items-center space-x-2 rounded"
    >
      <LinkedIn />
    </a>

    <a
      aria-label="GitHub's Nam Vo"
      href="https://github.com/vhnam"
      target="_blank"
      rel="noopener noreferrer"
      class="bg-gray-700 hover:bg-gray-600 active:bg-gray-800 p-2 font-semibold text-white inline-flex items-center space-x-2 rounded"
    >
      <GitHub />
    </a>

    <a
      aria-label="YouTube's Nam Vo"
      href="https://www.youtube.com/@namvo07"
      target="_blank"
      rel="noopener noreferrer"
      class="bg-red-700 hover:bg-red-600 active:bg-red-800 p-2 font-semibold text-white inline-flex items-center space-x-2 rounded"
    >
      <YouTube />
    </a>

    <a
      aria-label="Flickr's Nam Vo"
      href="https://www.flickr.com/photos/197719301@N02/"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex h-9 w-9 items-center justify-center space-x-2 rounded border border-stone-200/80 bg-white p-2 hover:bg-stone-50 active:bg-stone-200 dark:border-zinc-600 dark:bg-zinc-800 dark:hover:bg-zinc-700 dark:active:bg-zinc-600"
    >
      <Flickr />
    </a>
  </div>
</footer>
