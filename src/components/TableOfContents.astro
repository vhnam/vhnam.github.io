---
import TabletOfContentsHeading from "./TabletOfContentsHeading.astro";

type TableOfContent = {
  depth: number;
  text: string;
  slug: string;
  subheadings: TableOfContent[];
};

const { headings } = Astro.props;
const toc = buildToc(headings);

function buildToc(headings: TableOfContent[]) {
  let toc: TableOfContent[] = [];
  let parentHeadings = new Map();
  headings.forEach((h) => {
    let heading = { ...h, subheadings: [] };
    parentHeadings.set(heading.depth, heading);
    // Change 2 to 1 if your markdown includes your <h1>
    if (heading.depth === 1 || heading.depth === 2) {
      toc.push(heading);
    } else {
      parentHeadings.get(heading.depth - 1).subheadings.push(heading);
    }
  });
  return toc;
}
---

<nav
  class="max-w-xs text-stone-800 dark:text-zinc-200"
  aria-label="Mục lục"
>
  <div
    class="rounded-3xl border border-primary-200/50 bg-white/95 p-6 shadow-sm shadow-primary-500/8 backdrop-blur-sm dark:border-primary-800/40 dark:bg-zinc-900/80 dark:shadow-none"
  >
    <h2
      class="mb-6 border-b border-primary-200/70 pb-4 text-lg font-bold tracking-tight text-primary-950 dark:border-primary-800/50 dark:text-zinc-50"
    >
      Mục lục
    </h2>
    <ul class="flex flex-col gap-3 text-balance">
      {toc.map((heading) => <TabletOfContentsHeading heading={heading} />)}
    </ul>
  </div>
</nav>
