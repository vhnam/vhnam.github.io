---
import ImageZoom from "starlight-image-zoom/components/ImageZoom.astro";

import { GA_MEASUREMENT_ID } from "../consts";

import BaseHead from "../components/BaseHead.astro";
import CopyCodeButton from "../components/CopyCodeButton.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import Navigate from "../components/Navigate.astro";
import TableOfContents from "../components/TableOfContents.astro";

const {
  category,
  cover,
  description,
  headings,
  nextPost,
  prevPost,
  pubDate,
  tags,
  title,
} = Astro.props;
const articleDate = new Date(pubDate).toISOString();
---

<html lang="vi">
  <head>
    <BaseHead
      title={title}
      description={description}
      cover={cover?.src}
      articleDate={articleDate}
    />
  </head>

  <body>
    <ImageZoom />

    <Header />

    <main id="main-content" class="my-20">
      <div
        class="mb-12 border-b border-primary-200/55 bg-white/80 px-4 py-5 text-center backdrop-blur-md dark:border-primary-800/35 dark:bg-zinc-900/75 xl:py-20"
      >
        <h1
          class="mb-2 text-2xl font-semibold tracking-tight text-stone-900 sm:text-3xl lg:text-4xl dark:text-zinc-100 xl:mb-6"
        >
          {title}
        </h1>
        <div class="text-sm leading-6 mb-3">
          <dl>
            <dt class="sr-only">Ngày đăng</dt>
            <dd class="inset-x-0 text-stone-600 dark:text-zinc-400">
              Ngày đăng
              <time datetime={pubDate.toISOString()}>
                <FormattedDate pubDate={pubDate} />
              </time>
            </dd>
          </dl>
        </div>
        <div class="flex justify-center">
          <div class="flex flex-wrap gap-1">
            {
              tags.map((tag: string) => (
                <span
                  class="me-2 rounded-full border border-primary-200/70 bg-primary-50/60 px-2.5 py-1 text-xs font-semibold tracking-wide text-primary-900 backdrop-blur-sm dark:border-primary-700/50 dark:bg-primary-950/35 dark:text-primary-200"
                >
                  #{tag}
                </span>
              ))
            }
          </div>
        </div>
      </div>

      <div class="container mx-auto pb-20">
        <div class="flex flex-row px-4 xl:px-8 gap-8">
          <!-- aside  -->
          <aside class="xl:w-3/12 shrink-0 hidden lg:block">
            <div
              class="sticky top-24 self-start hidden lg:block transition-all duration-200"
            >
              {
                headings && headings.length > 0 && (
                  <TableOfContents {headings} />
                )
              }
            </div>
          </aside>

          <!-- post -->
          <article class="w-full xl:w-9/12 shrink-0">
            <div class="mb-12 min-w-full content">
              <slot />
            </div>
          </article>
        </div>
      </div>

      <!-- related posts -->
      <Navigate category={category} {prevPost} {nextPost} />
    </main>

    <Footer />

    <CopyCodeButton />

    <script>
      const fnObserver = () => {
        function handleIntersection(
          entries: IntersectionObserverEntry[],
          _observer: IntersectionObserver
        ) {
          entries.forEach((entry) => {
            const index = document.querySelector(
              `aside a[href="#${entry.target.id}"]`
            );

            if (entry.isIntersecting) {
              index?.classList.remove(
                "text-stone-800",
                "dark:text-zinc-200",
                "font-medium"
              );
              index?.classList.add(
                "rounded-lg",
                "bg-primary-600",
                "dark:bg-primary-700",
                "text-white",
                "font-bold",
                "shadow-sm",
                "shadow-primary-600/25",
                "transition-colors",
                "duration-200"
              );
            } else {
              index?.classList.remove(
                "rounded-lg",
                "bg-primary-600",
                "dark:bg-primary-700",
                "text-white",
                "font-bold",
                "shadow-sm",
                "shadow-primary-600/25",
                "transition-colors",
                "duration-200"
              );
              index?.classList.add(
                "text-stone-800",
                "dark:text-zinc-200",
                "font-medium"
              );
            }
          });
        }

        const headings = document.querySelectorAll(
          "div h1, div h2, div h3, div h4, div h5, div h6"
        );

        const options = {
          root: null,
          rootMargin: " 15% 0px 0% 0px ",
          threshold: 1,
        };

        const observer = new IntersectionObserver(handleIntersection, options);

        headings.forEach((heading) => {
          observer.observe(heading);
        });
      };
      fnObserver();
      document.addEventListener("astro:after-swap", fnObserver);
    </script>

    <!-- Google Analytics 4 -->
    <script
      is:inline
      async
      type="text/partytown"
      src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
    ></script>

    <script is:inline type="text/partytown" define:vars={{ GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];

      function gtag() {
        window.dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", GA_MEASUREMENT_ID);
    </script>
  </body>
</html>
