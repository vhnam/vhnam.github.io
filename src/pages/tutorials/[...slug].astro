---
import {
  type CollectionEntry,
  getCollection,
  getEntry,
  render,
} from "astro:content";

import {
  type CollectionNavPost,
  collectionNavSlice,
} from "../../utils/collectionNav";
import { sortByDate } from "../../utils/sortByDate";

import PostLayout from "../../layouts/PostLayout.astro";

type TutorialEntry = CollectionEntry<"tutorial">;

export async function getStaticPaths() {
  const posts = await getCollection("tutorial");
  const numberOfPosts = posts.length;
  const sorted = [...posts].sort(sortByDate);

  return sorted.map((post, index: number) => ({
    params: { slug: post.id },
    props: {
      id: post.id,
      prevPost:
        index + 1 === numberOfPosts
          ? null
          : collectionNavSlice(sorted[index + 1]!),
      nextPost:
        index === 0 ? null : collectionNavSlice(sorted[index - 1]!),
    },
  }));
}

type Props = {
  id: TutorialEntry["id"];
  nextPost: CollectionNavPost | null;
  prevPost: CollectionNavPost | null;
};

const { id, nextPost, prevPost } = Astro.props as Props;

const entry = await getEntry("tutorial", id);
if (!entry) {
  return Astro.redirect("/404");
}

const { Content, headings } = await render(entry);
const { title, description, cover, pubDate, tags } = entry.data;
---

<PostLayout
  title={title}
  description={description}
  cover={cover}
  category="tutorials"
  headings={headings}
  pubDate={pubDate}
  tags={tags ?? []}
  {nextPost}
  {prevPost}
>
  <Content />
</PostLayout>
