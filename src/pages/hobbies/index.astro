---
import { getCollection } from "astro:content";

import { GA_MEASUREMENT_ID } from "../../consts";

import { getTags } from "../../utils/post";
import { sortByDate } from "../../utils/sortByDate";

import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import PostItem from "../../components/PostItem.astro";
import Tag from "../../components/Tag.astro";

const posts = (await getCollection("hobby")).sort(sortByDate);
const tags = getTags(posts);
---

<!doctype html>
<html lang="vi">
  <head>
    <BaseHead title="Giải trí" />
  </head>
  <body>
    <Header />

    <main id="main-content" class="my-20">
      <div
        class="mb-12 border-b border-primary-200/55 bg-white/80 px-4 py-5 text-center backdrop-blur-md dark:border-primary-800/35 dark:bg-zinc-900/75 xl:py-20"
      >
        <h1
          class="mb-2 text-2xl font-semibold tracking-tight text-stone-900 sm:text-3xl lg:text-4xl dark:text-zinc-100 xl:mb-6"
        >
          Giải trí
        </h1>
        <p class="text-sm leading-6 text-stone-600 dark:text-zinc-400">
          {posts.length} bài viết
        </p>
      </div>

      <div class="container mx-auto pb-20">
        <div class="flex flex-row px-4 xl:px-8 gap-8">
          <aside class="xl:w-3/12 shrink-0 hidden lg:block">
            <div
              class="sticky top-24 self-start hidden lg:block transition-all duration-200"
            >
              <h2
                class="mb-2 text-2xl font-semibold tracking-tight text-stone-900 lg:text-3xl dark:text-zinc-100"
              >
                Bài viết mới nhất
              </h2>
              <div class="flex flex-wrap gap-1">
                {
                  Object.keys(tags).map((slug) => (
                    <Tag tag={(tags as any)[slug]} slug={slug} />
                  ))
                }
              </div>
            </div>
          </aside>

          <section class="basis-full md:basis-9/12">
            <div class="mb-12 min-w-full">
              <ul class="flex flex-col gap-4 md:gap-6 pb-6">
                {
                  posts.map((post) => (
                    <PostItem post={post} category="hobbies" />
                  ))
                }
              </ul>
            </div>
          </section>
        </div>
      </div>
    </main>

    <Footer />

    <script
      is:inline
      type="text/partytown"
      async
      src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
    ></script>

    <script is:inline type="text/partytown" define:vars={{ GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];

      function gtag() {
        window.dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", GA_MEASUREMENT_ID);
    </script>
  </body>
</html>
