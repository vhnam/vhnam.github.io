---
import { getCollection } from "astro:content";
import { Image, getImage } from "astro:assets";

import { GA_MEASUREMENT_ID, SITE_TITLE } from "../consts";

import { getTags } from "../utils/post";
import { sortByDate } from "../utils/sortByDate";

import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import LatestPostItem from "../components/LatestPostItem.astro";
import PostItem from "../components/PostItem.astro";
import Tag from "../components/Tag.astro";

import avatarImg from "../assets/images/namvh.jpeg";
import headerImg from "../assets/images/tao-dan-band.jpeg";

const tutorials = await getCollection("tutorial");
const hobbies = await getCollection("hobby");

const allPosts = [...hobbies, ...tutorials].sort(sortByDate);
const latestPosts = allPosts.slice(0, 6);
const posts = [...tutorials].sort(sortByDate).slice(0, 4);

const optimizedBackground = await getImage({ src: headerImg, format: "webp" });

const tags = getTags(allPosts);
---

<!doctype html>
<html lang="vi">
  <head>
    <BaseHead />
  </head>
  <body>
    <Header />

    <main id="main-content">
      <div
        class="border-b border-primary-200/55 bg-white/75 backdrop-blur-sm dark:border-primary-800/35 dark:bg-zinc-900/70"
      >
        <div class="container mx-auto">
          <header
            aria-hidden="true"
            class="flex items-center justify-center h-[40vh] md:h-[50vh] mb-12 bg-fixed bg-bottom bg-size-[180%] md:bg-cover mt-20 rounded-b-lg bg-position-[center_top_-10vh] md:bg-position-[center_bottom]"
            style={`background-image: url(${optimizedBackground.src});`}
          >
          </header>
        </div>

        <section class="container mx-auto" aria-labelledby="intro-heading">
          <div class="-mt-28 px-8 pb-2 md:pb-0">
            <h1 id="intro-heading" class="sr-only">
              Trang chủ — {SITE_TITLE}
            </h1>
            <h2 class="sr-only">Giới thiệu bản thân</h2>
            <div
              class="flex flex-col xl:flex-row md:inline-flex items-center md:items-end mb-6"
            >
              <Image
                class="rounded-full border-2 border-white shadow-lg shadow-primary-500/25 ring-4 ring-white/90 ring-primary-100/80 dark:border-zinc-600 dark:shadow-primary-900/20 dark:ring-zinc-900/80 dark:ring-primary-900/30"
                src={avatarImg}
                alt="Nam Vo"
                width={160}
                height={160}
                quality="mid"
              />
              <p
                class="text-center text-stone-700 md:ml-6 md:text-left dark:text-zinc-300"
              >
                <strong
                  class="mb-2 font-display text-2xl text-stone-900 md:text-3xl dark:text-zinc-100"
                  >Nam Vo</strong
                >
                <span
                  class="font-display mb-3 block text-xs font-semibold text-primary-600 dark:text-primary-400 md:mb-0"
                  >Software Engineer | Trumpeter</span
                >
                <span class="block text-sm"
                  >Đây là website cá nhân để lưu lại những kiến thức đã tích lũy
                  trong thời gian qua. Và cũng như chia sẻ chúng với mọi người.</span
                >
              </p>
            </div>
          </div>
        </section>
      </div>

      <section class="container mx-auto px-4 md:px-8 py-10">
        <h2
          class="mb-6 text-sm font-semibold leading-6 tracking-wide text-primary-600 dark:text-primary-400"
        >
          Bài viết mới
        </h2>
        <ul class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestPosts.map((post) => <LatestPostItem post={post} />)}
        </ul>
      </section>

      <div class="container mx-auto py-10">
        <div class="flex flex-row px-4 md:px-8 gap-8">
          <section class="basis-full md:basis-8/12">
            <div class="py-6">
              <h2
                class="mb-6 text-sm font-semibold leading-6 tracking-wide text-primary-600 dark:text-primary-400"
              >
                Chia sẻ về Công nghệ Phần mềm
              </h2>
              <ul class="flex flex-col gap-6 pb-6">
                {
                  posts.map((post) => (
                    <PostItem post={post} category="tutorials" />
                  ))
                }
              </ul>
              <div class="text-right">
                <a
                  href="/tutorials"
                  class="border-b border-b-primary-400 text-stone-900 hover:border-b-2 dark:text-zinc-100"
                  >» Xem thêm</a
                >
              </div>
            </div>
          </section>

          <section class="basis-full md:basis-4/12 hidden md:block">
            <div class="py-6">
              <h2
                class="mb-6 text-sm font-semibold leading-6 tracking-wide text-primary-600 dark:text-primary-400"
              >
                Khám phá thêm các chủ đề
              </h2>
              <div class="flex flex-wrap gap-1">
                {
                  Object.keys(tags).map((slug) => (
                    <Tag tag={tags[slug]} slug={slug} />
                  ))
                }
              </div>
            </div>
          </section>
        </div>
      </div>
    </main>

    <Footer />

    <!-- Google Analytics 4 -->
    <script
      is:inline
      async
      type="text/partytown"
      src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
    ></script>

    <script is:inline type="text/partytown" define:vars={{ GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];

      function gtag() {
        window.dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", GA_MEASUREMENT_ID);
    </script>
  </body>
</html>
